# ============================================
# roofpanels Backend — Environment Variables
# ============================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/roofpanels
# For MongoDB Atlas (cloud), use:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/roofpanels?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=roofpanels_super_secret_jwt_key_change_this_in_production_2025
JWT_EXPIRE=7d

# --- Admin Seed Credentials ---
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@roofpanels.pk
ADMIN_PASSWORD=admin123

# --- CORS ---
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# --- Cloudinary (Image Uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Email (Nodemailer / Gmail SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=roofpanels <your_gmail@gmail.com>

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

MONGO_URI=mongodb://localhost:27017/roofpanels
ADMIN_EMAIL=admin@pvcpanels.com
ADMIN_PASSWORD=Admin@123456